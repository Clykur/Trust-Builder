# Server
PORT=5000

# Database: use either (1) Supabase or (2) direct Postgres

# --- Option 1: Supabase ---
# From Supabase: Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# From Supabase: Project Settings → API → service_role (secret; server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Option 2: Direct Postgres (e.g. Drizzle) ---
# Connection string for PostgreSQL (or use Supabase: Project Settings → Database → Connection string)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Client (optional: for Supabase Auth / Realtime in the browser) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
